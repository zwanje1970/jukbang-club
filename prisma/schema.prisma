// JUKBANG.CLUB - MySQL + Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum UserRole {
  USER
  ADMIN
}

enum CompetitionType {
  UNDER_06
  UNDER_07
  UNDER_08
  UNDER_09
  UNDER_10
  EVER
}

enum BroadcastStatus {
  LIVE
  WAITING
  ENDED
}

enum RoundType {
  PRELIMINARY
  SEMI
  FINAL
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  email     String
  phone     String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications    Application[]
  lessonApps      LessonApplication[]
  boardPosts      BoardPost[]
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model Competition {
  id              String          @id @default(cuid())
  name            String
  date            DateTime
  type            CompetitionType
  maxParticipants Int             @default(30)
  entryFee        Int             @default(70000)
  operatingFee    Int             @default(10000)
  imageUrl        String?
  description     String?         @db.Text
  status          String          @default("open")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  applications Application[]
}

model Application {
  id             String    @id @default(cuid())
  userId         String
  competitionId  String
  depositorName  String
  score          String
  recordImageUrl String?
  paidAt         DateTime?
  round          RoundType?
  prize          Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([userId, competitionId])
  @@index([userId])
  @@index([competitionId])
}

model Lesson {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  imageUrl  String?
  fee       Int
  period    String
  content   String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications LessonApplication[]
}

model LessonApplication {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Board {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  posts BoardPost[]
}

model BoardPost {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  title     String
  content   String   @db.Text
  reply     String?  @db.Text
  replyAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([userId])
}

model Venue {
  id          String   @id @default(cuid())
  name        String
  address     String
  description String?  @db.Text
  imageUrl    String?
  lat         Float?
  lng         Float?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BroadcastTable {
  id         String          @id @default(cuid())
  tableNumber Int            @unique
  youtubeUrl String?
  status     BroadcastStatus @default(WAITING)
  isActive   Boolean         @default(false)
  updatedAt  DateTime        @updatedAt
}
