# 로컬 개발: 이 파일을 복사해 .env.local 로 저장한 뒤 값을 채우세요.
# 배포(Vercel): 프로젝트 설정 > Environment Variables 에서 DATABASE_URL 을 설정하세요.
# Neon PostgreSQL: Pooled connection 권장. 슬립 후 첫 연결이 느리면 connect_timeout=15 추가
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# 네이버 지도 API (당구장안내 페이지). 네이버 클라우드 플랫폼에서 발급한 Client ID.
# 미설정 시 지도는 '네이버 지도에서 보기' iframe으로 표시됩니다.
# NEXT_PUBLIC_NAVER_MAP_CLIENT_ID="YOUR_NCP_CLIENT_ID"

# Vercel Blob (이미지 업로드). Vercel 대시보드에서 Blob 스토어 생성 시 자동 발급.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
