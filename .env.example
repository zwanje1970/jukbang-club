# 로컬 개발: 이 파일을 복사해 .env.local 로 저장한 뒤 값을 채우세요.
# 배포(Vercel): 프로젝트 설정 > Environment Variables 에서 DATABASE_URL 을 설정하세요.
# Neon PostgreSQL 예시 (Neon 대시보드에서 Connection string 복사 후 ?sslmode=require 추가)

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# 네이버 지도 API (대회당구장 안내 페이지). 네이버 클라우드 플랫폼에서 발급한 Client ID.
# 미설정 시 지도는 '네이버 지도에서 보기' iframe으로 표시됩니다.
# NEXT_PUBLIC_NAVER_MAP_CLIENT_ID="YOUR_NCP_CLIENT_ID"
